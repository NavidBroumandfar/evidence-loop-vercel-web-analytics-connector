include README.md
include LICENSE
include CHANGELOG.md
include SECURITY.md
include AGENTS.md

recursive-include docs *.md
recursive-include examples *.json
recursive-include scripts *.py
recursive-include tests *.py *.json

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.pyc
prune build
prune dist
prune *.egg-info
